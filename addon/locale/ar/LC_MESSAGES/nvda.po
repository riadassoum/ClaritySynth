msgid "Adam (formant, low)"
msgstr "آدم (صياغي، منخفض)"

msgid "Clara (formant, high)"
msgstr "كلارا (صياغي، مرتفع)"

msgid "Robby (formant, robot)"
msgstr "روبي (صياغي، آلي)"

#. Translators: downloads window — Tools menu item.
msgid "ClaritySynth voice && model downloads..."
msgstr "تنزيلات أصوات ونماذج كلاريتي سينث..."

msgid "Download extra Arabic voices, vocoders and tashkeel libraries for ClaritySynth"
msgstr "تنزيل أصوات عربية إضافية ومحولات صوتية ومكتبات تشكيل لكلاريتي سينث"

#. Translators: update check — Tools menu item.
msgid "Check for ClaritySynth &updates..."
msgstr "التحقق من &تحديثات كلاريتي سينث..."

msgid "Check GitHub for a newer version of ClaritySynth"
msgstr "التحقق من غيت هاب من وجود إصدار أحدث لكلاريتي سينث"

msgid "ClaritySynth downloads"
msgstr "تنزيلات كلاريتي سينث"

msgid "Download extra voices, vocoders and tashkeel libraries. Voices marked \"RT streaming\" are the fastest. Installed items are marked. They take effect the next time you switch to ClaritySynth."
msgstr "نزّل أصواتًا ومحولات صوتية ومكتبات تشكيل إضافية. الأصوات الموسومة بـ\"RT streaming\" هي الأسرع. العناصر المثبَّتة موسومة. تُطبَّق عند التبديل إلى كلاريتي سينث في المرة التالية."

msgid "Ready."
msgstr "جاهز."

msgid "&Download selected"
msgstr "&تنزيل المحدَّد"

msgid "&Cancel download"
msgstr "إ&لغاء التنزيل"

msgid "Cl&ose"
msgstr "إ&غلاق"

msgid "[installed] "
msgstr "[مثبَّت] "

#. Translators: %s is the item description.
msgid "Already installed: %s"
msgstr "مثبَّت بالفعل: %s"

#. Translators: %s is the item description.
msgid "Downloading %s ..."
msgstr "جارٍ تنزيل %s ..."

#. Translators: %s is the item description.
msgid "Installed: %s"
msgstr "تم تثبيت: %s"

msgid "Cancelled."
msgstr "أُلغي."

msgid "Cancelling..."
msgstr "جارٍ الإلغاء..."

msgid "Download failed. Check your internet connection and try again."
msgstr "فشل التنزيل. تحقق من اتصالك بالإنترنت وحاول مرة أخرى."

#. Translators: %s is the error message.
msgid "Error: %s"
msgstr "خطأ: %s"

msgid "ClaritySynth is up to date."
msgstr "كلاريتي سينث محدَّث."

msgid "ClaritySynth update"
msgstr "تحديث كلاريتي سينث"

msgid "ClaritySynth update available"
msgstr "يتوفَّر تحديث لكلاريتي سينث"

#. Translators: {ver} is the version, {changelog} the release notes.
msgid ""
"A new version of ClaritySynth is available: {ver}\n"
"\n"
"What's new:\n"
"{changelog}\n"
"\n"
"Open the download page now?"
msgstr ""
"يتوفَّر إصدار جديد من كلاريتي سينث: {ver}\n"
"\n"
"الجديد:\n"
"{changelog}\n"
"\n"
"هل تريد فتح صفحة التنزيل الآن؟"

msgid "(no changelog provided)"
msgstr "(لا يوجد سجل تغييرات)"

#. Translators: download progress detail with elapsed and remaining time.
msgid "%(pct)d%%  -  %(got)s of %(total)s  -  elapsed %(el)s, remaining %(rem)s"
msgstr "%(pct)d%%  -  %(got)s من %(total)s  -  مضى %(el)s، يتبقى %(rem)s"

#. Translators: download progress when total size is unknown.
msgid "%(got)s downloaded  -  elapsed %(el)s"
msgstr "تم تنزيل %(got)s  -  مضى %(el)s"

msgid "Updating ClaritySynth"
msgstr "جارٍ تحديث كلاريتي سينث"

#. Translators: %s is the version.
msgid "Downloading version %s ..."
msgstr "جارٍ تنزيل الإصدار %s ..."

#. Translators: %.1f are megabytes downloaded and total.
msgid "Downloaded %.1f of %.1f MB"
msgstr "تم تنزيل %.1f من %.1f ميغابايت"

#. Translators: %.1f is megabytes downloaded.
msgid "Downloaded %.1f MB"
msgstr "تم تنزيل %.1f ميغابايت"

#. Translators: {ver} version, {changelog} notes — direct install prompt.
msgid ""
"A new version of ClaritySynth is available: {ver}\n"
"\n"
"What's new:\n"
"{changelog}\n"
"\n"
"Download and install it now?"
msgstr ""
"يتوفَّر إصدار جديد من كلاريتي سينث: {ver}\n"
"\n"
"الجديد:\n"
"{changelog}\n"
"\n"
"هل تريد تنزيله وتثبيته الآن؟"

msgid "Update installed"
msgstr "تم تثبيت التحديث"

msgid ""
"ClaritySynth has been updated. NVDA must restart to finish. Restart now?"
msgstr "تم تحديث كلاريتي سينث. يجب إعادة تشغيل NVDA لإتمام العملية. إعادة التشغيل الآن؟"

#. Translators: Tools menu item for the batch diacritization window.
msgid "Diacritize Arabic text (&tashkeel)..."
msgstr "تشكيل نص عربي (&تشكيل)..."

msgid "Add diacritics to Arabic text using a chosen tashkeel library, whatever synthesizer is active"
msgstr "إضافة التشكيل إلى نص عربي باستخدام مكتبة تشكيل مختارة، أيًّا كان الناطق المُفعَّل"

msgid "Diacritize Arabic text"
msgstr "تشكيل نص عربي"

msgid "Enter or paste Arabic text of any length, choose a tashkeel library, and press Diacritize. The result appears below, ready to copy. This works no matter which synthesizer you are using."
msgstr "أدخل أو الصق نصًّا عربيًّا بأي طول، واختر مكتبة تشكيل، ثم اضغط تشكيل. تظهر النتيجة في الأسفل جاهزة للنسخ. يعمل هذا أيًّا كان الناطق الذي تستخدمه."

msgid "&Text to diacritize:"
msgstr "ال&نص المراد تشكيله:"

msgid "Tashkeel &library:"
msgstr "&مكتبة التشكيل:"

msgid "&Diacritize"
msgstr "&تشكيل"

msgid "&Result:"
msgstr "ال&نتيجة:"

msgid "C&opy result"
msgstr "&نسخ النتيجة"

msgid "Please enter some Arabic text first."
msgstr "الرجاء إدخال نص عربي أولاً."

msgid "Diacritizing..."
msgstr "جارٍ التشكيل..."

#. Translators: %(done)d and %(total)d are counts of processed pieces.
msgid "Diacritizing... %(done)d of %(total)d"
msgstr "جارٍ التشكيل... %(done)d من %(total)d"

msgid "Done."
msgstr "تمّ."

msgid "Result copied to the clipboard."
msgstr "تم نسخ النتيجة إلى الحافظة."

msgid "Could not copy to the clipboard."
msgstr "تعذّر النسخ إلى الحافظة."

