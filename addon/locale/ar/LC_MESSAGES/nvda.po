#. Translators: the name of the neural synthesizer driver.
msgid "ClaritySynth Neural"
msgstr "كلاريتي سينث العصبي"

#. Translators: the name of the formant synthesizer driver.
msgid "ClaritySynth Formant"
msgstr "كلاريتي سينث الصياغي"

#. Translators: Tashkeel (diacritization) library setting.
msgid "&Tashkeel library (Arabic diacritization)"
